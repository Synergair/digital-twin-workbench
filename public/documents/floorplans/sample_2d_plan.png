<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Floorplanner.com - 404 - Page not found</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <style type="text/css">
      * {
        box-sizing: border-box;
      }

      html {
        width: 100%;
        height: 100%;
        background-color: #f8f9fa;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      }

      body {
        width: 100%;
        height: 100%;
        margin: 0;
        font-family: 'Lato', system-ui, sans-serif;
        color: black;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        padding: 0.5rem;
        gap: 0.5rem;
        border-bottom: solid 1px #aaa;
        background-color: #eee;
      }

      nav a {
        display: inline-block;
        min-width: 9rem;
        padding: 0.5rem;
        border-radius: 0.2rem;
        border: solid 1px #aaa;
        text-align: center;
        text-decoration: none;
        color: #555;
        transition: all 0.3s ease;
      }

      nav a:hover {
        background-color: #d4d4d4;
        transform: translateY(-2px);
      }

      nav a[aria-current='page'] {
        color: #000;
        background-color: #d4d4d4;
      }

      main {
        padding: 1rem;
      }

      h1 {
        font-weight: bold;
        font-size: 1.5rem;
      }

      /* 404 Error Page Styles */
      .error-page {
        min-height: calc(100vh - 70px);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .error-content {
        max-width: 600px;
        padding: 2rem;
        animation: fadeIn 0.8s ease-out;
      }

      .error-title {
        font-size: 10rem;
        font-weight: 900;
        color: #2196f3;
        margin: 0;
        line-height: 1;
        text-shadow: 4px 4px 0px rgba(33, 150, 243, 0.2);
        animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      }

      .error-message {
        font-size: 2rem;
        font-weight: 700;
        color: #333;
        margin: 1rem 0;
        animation: slideUp 0.6s ease-out 0.2s both;
      }

      .error-description {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 2rem;
        animation: slideUp 0.6s ease-out 0.4s both;
      }

      .error-button {
        display: inline-block;
        padding: 1rem 2.5rem;
        background-color: #2196f3;
        color: white;
        text-decoration: none;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 6px rgba(33, 150, 243, 0.2);
        animation: slideUp 0.6s ease-out 0.6s both;
      }

      .error-button:hover {
        background-color: #d2a719;
        transform: translateY(-2px);
        box-shadow: 0 6px 8px rgba(33, 150, 243, 0.3);
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes scaleIn {
        from {
          transform: scale(0.8);
          opacity: 0;
        }
        to {
          transform: scale(1);
          opacity: 1;
        }
      }

      @keyframes slideUp {
        from {
          transform: translateY(20px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }
  </style>
  </head>
  <body>
    <main class="error-page">
      <div class="error-content">
        <img src="https://cdn.floorplanner.com/static/logo.svg" width="350" />
        <br/><br/>
        <h1 class="error-title">404</h1>
        <p class="error-message">Oops! The data you're looking for doesn't exist</p>
        <p class="error-description">The date might have been moved or deleted.</p>
        <a href="/" class="error-button">Back to Homepage</a>
      </div>
    </main>
  </body>
</html>
